{
    "tasks": [
        {
            "type": "cppbuild",
            "label": "C/C++: gcc.exe build active file",
            "command": "E:\\Programs\\ucrt64\\bin\\gcc.exe",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "-I${workspaceFolder}\\BinaryTrees\\Common",
                "${file}",
                "${workspaceFolder}\\BinaryTrees\\Common\\queue.c",
                "${workspaceFolder}\\BinaryTrees\\Common\\tree.c",
                "${workspaceFolder}\\BinaryTrees\\Common\\hash_table.c",
                "${workspaceFolder}\\BinaryTrees\\LabEx2\\BinaryTreeSearch.c",
                "-o",
                "${fileDirname}\\${fileBasenameNoExtension}.exe"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Task generated by Debugger."
        },
        {
            "label": "C/C++: Run active file",
            "type": "shell",
            "command": "${fileDirname}\\${fileBasenameNoExtension}.exe",
            "options": {
                "cwd": "${fileDirname}"
            },
            "dependsOn": "C/C++: gcc.exe build active file",
            "group": {
                "kind": "build"
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "shared"
            }
        }
    ],
    "version": "2.0.0"
}